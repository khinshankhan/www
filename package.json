{
  "name": "www",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:excalidraw": "node scripts/sync-excalidraw-assets.mjs",
    "content:new": "node scripts/new-writing-article.mjs",
    "content:components": "node scripts/generate-content-component-manifest.mjs",
    "typecheck": "pnpm run content:components && tsc --noEmit",
    "next-lint": "pnpm run content:components && eslint .",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "pnpm run content:components && pnpm run typecheck && pnpm run next-lint && pnpm run format:check",
    "dev": "pnpm run content:components && next dev --turbopack",
    "build": "pnpm run content:components && next build --turbopack",
    "start": "next start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
